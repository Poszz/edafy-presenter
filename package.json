{
  "name": "edafy-platform-slides",
  "version": "3.0.0",
  "description": "Edafy Platform – OTC Malaysia 2026 Presentation",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "build": {
    "appId": "my.afeddigital.edafy-presenter",
    "productName": "EDAFY Presenter",
    "copyright": "Copyright © 2026 AFED Digital",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "public/icon.png",
      "target": ["AppImage", "deb"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerSidebar": null,
      "deleteAppDataOnUninstall": true,
      "guid": "edafy-presenter-2026-otc",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EDAFY Presenter",
      "uninstallDisplayName": "EDAFY Presenter",
      "include": "build/installer.nsh",
      "perMachine": true
    }
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "lucide-react": "0.522.0",
    "three": "^0.170.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}